---
import SearchIcon from "@/assets/icons/search.svg"
---

<site-search>
  <button
    data-search-trigger
    data-icon-button
    aria-label="Search"
    aria-keyshortcuts="Meta+K Control+K"
  >
    <SearchIcon />
  </button>
  <dialog data-search-dialog aria-label="Search">
    <search-panel>
      <search-field>
        <SearchIcon />
        <input
          type="search"
          data-search-input
          placeholder="Search posts…"
          autocomplete="off"
          autocapitalize="off"
          autocorrect="off"
          spellcheck="false"
          enterkeyhint="search"
          aria-label="Search posts"
        >
        <kbd>Esc</kbd>
      </search-field>
      <search-results
        data-search-results
        role="listbox"
        aria-label="Search results"
      ></search-results>
    </search-panel>
  </dialog>
</site-search>

<style>
  site-search {
    display: contents;
  }

  dialog {
    width: min(40rem, calc(100vw - 2 * var(--space-m)));
    max-height: min(28rem, calc(100svh - 2 * var(--space-xl)));
    margin-block-start: max(var(--space-2xl), 12svh);
    margin-inline: auto;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background-color: var(--background);
    color: var(--foreground);
    box-shadow: 0 16px 48px -12px color-mix(in oklab, black 40%, transparent);
    overflow: hidden;

    &::backdrop {
      background-color: color-mix(in oklab, var(--background) 60%, transparent);
      backdrop-filter: blur(4px);
    }
  }

  search-panel {
    display: flex;
    flex-direction: column;
    min-height: 0;
    max-height: inherit;
  }

  search-field {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    padding-inline: var(--space-s);
    border-block-end: 1px solid var(--border);

    svg {
      width: 1.125rem;
      height: 1.125rem;
      flex-shrink: 0;
      color: var(--muted-foreground);
    }

    input {
      flex: 1;
      min-width: 0;
      padding-block: var(--space-s);
      border: none;
      background: transparent;
      color: var(--foreground);
      font: inherit;
      font-size: var(--step-0);
      line-height: 1.2;

      &::placeholder {
        color: var(--muted-foreground);
      }

      &:focus {
        outline: none;
      }

      &::-webkit-search-cancel-button {
        appearance: none;
      }
    }

    kbd {
      flex-shrink: 0;
      padding-inline: var(--space-2xs);
      padding-block: 0.125rem;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background-color: var(--muted);
      color: var(--muted-foreground);
      font-size: var(--step--1);
      font-family: var(--font-mono, monospace);
      line-height: 1.4;
    }
  }

  search-results {
    display: block;
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: var(--space-2xs);

    &:empty {
      display: none;
    }
  }

  search-results :global(.search-empty) {
    padding: var(--space-s);
    color: var(--muted-foreground);
    font-size: var(--step--1);
    text-align: center;
  }

  search-results :global(a) {
    display: block;
    padding: var(--space-2xs) var(--space-s);
    border-radius: var(--radius-md);
    color: var(--foreground);
    text-decoration: none;

    &:hover,
    &[data-active="true"] {
      background-color: color-mix(in oklab, var(--muted) 60%, transparent);
    }
  }

  search-results :global(.search-result-title) {
    font-weight: var(--font-weight-medium);
    font-size: var(--step-0);
  }

  search-results :global(.search-result-excerpt) {
    margin-block-start: 0.125rem;
    color: var(--muted-foreground);
    font-size: var(--step--1);
    line-height: calc(var(--leading-offset) + 1em);

    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  search-results :global(mark) {
    background-color: color-mix(in oklab, var(--accent) 25%, transparent);
    color: inherit;
    border-radius: var(--radius-xs);
  }
</style>

<script>
  type PagefindResultData = {
    url: string
    meta: { title?: string }
    excerpt: string
  }

  type PagefindApi = {
    init?: () => Promise<void>
    search: (
      query: string,
    ) => Promise<{ results: { data: () => Promise<PagefindResultData> }[] }>
  }

  const MAX_RESULTS = 8

  class SiteSearch extends HTMLElement {
    private dialog = this.querySelector<HTMLDialogElement>(
      "[data-search-dialog]",
    )!
    private trigger = this.querySelector<HTMLButtonElement>(
      "[data-search-trigger]",
    )!
    private input = this.querySelector<HTMLInputElement>("[data-search-input]")!
    private results = this.querySelector<HTMLElement>("[data-search-results]")!

    private pagefind: PagefindApi | null = null
    private loadPromise: Promise<PagefindApi | null> | null = null
    private debounce = 0
    private activeIndex = -1

    connectedCallback() {
      this.trigger.addEventListener("click", () => this.open())
      document.addEventListener("keydown", this.onGlobalKeydown)
      this.input.addEventListener("input", this.onInput)
      this.results.addEventListener("mousemove", this.onResultsHover)
      this.dialog.addEventListener("keydown", this.onDialogKeydown)
      // Close when clicking the backdrop (outside the panel).
      this.dialog.addEventListener("click", (event) => {
        if (event.target === this.dialog) this.close()
      })
      this.dialog.addEventListener("close", () => this.reset())
    }

    disconnectedCallback() {
      document.removeEventListener("keydown", this.onGlobalKeydown)
    }

    private onGlobalKeydown = (event: KeyboardEvent) => {
      if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
        event.preventDefault()
        this.dialog.open ? this.close() : this.open()
      }
    }

    private open() {
      if (this.dialog.open) return
      this.dialog.showModal()
      this.input.focus()
      void this.loadPagefind()
    }

    private close() {
      if (this.dialog.open) this.dialog.close()
    }

    private reset() {
      this.input.value = ""
      this.results.replaceChildren()
      this.activeIndex = -1
    }

    private async loadPagefind(): Promise<PagefindApi | null> {
      if (this.pagefind) return this.pagefind
      if (this.loadPromise) return this.loadPromise

      this.loadPromise = (async () => {
        try {
          const url = `${import.meta.env.BASE_URL}pagefind/pagefind.js`
          const mod = (await import(/* @vite-ignore */ url)) as PagefindApi
          await mod.init?.()
          this.pagefind = mod
          return mod
        } catch {
          this.renderMessage(
            "Search is only available in the production build.",
          )
          return null
        }
      })()

      return this.loadPromise
    }

    private onInput = () => {
      window.clearTimeout(this.debounce)
      this.debounce = window.setTimeout(() => void this.run(), 150)
    }

    private async run() {
      const query = this.input.value.trim()
      if (!query) {
        this.results.replaceChildren()
        this.activeIndex = -1
        return
      }

      const pagefind = await this.loadPagefind()
      if (!pagefind) return
      // Ignore stale runs if the query changed while awaiting.
      if (this.input.value.trim() !== query) return

      const search = await pagefind.search(query)
      if (this.input.value.trim() !== query) return

      const items = await Promise.all(
        search.results.slice(0, MAX_RESULTS).map((result) => result.data()),
      )
      if (this.input.value.trim() !== query) return

      this.renderResults(items)
    }

    private renderMessage(message: string) {
      const el = document.createElement("div")
      el.className = "search-empty"
      el.textContent = message
      this.results.replaceChildren(el)
      this.activeIndex = -1
    }

    private renderResults(items: PagefindResultData[]) {
      if (items.length === 0) {
        this.renderMessage("No results found.")
        return
      }

      const fragment = document.createDocumentFragment()
      for (const item of items) {
        const link = document.createElement("a")
        link.href = item.url
        link.setAttribute("role", "option")

        const title = document.createElement("div")
        title.className = "search-result-title"
        title.textContent = item.meta.title ?? item.url

        const excerpt = document.createElement("div")
        excerpt.className = "search-result-excerpt"
        excerpt.innerHTML = item.excerpt

        link.append(title, excerpt)
        fragment.append(link)
      }

      this.results.replaceChildren(fragment)
      this.activeIndex = -1
    }

    private get links() {
      return Array.from(this.results.querySelectorAll<HTMLAnchorElement>("a"))
    }

    private onResultsHover = (event: MouseEvent) => {
      const link = (event.target as HTMLElement).closest("a")
      if (!link) return
      this.setActive(this.links.indexOf(link))
    }

    private setActive(index: number) {
      const links = this.links
      this.activeIndex = index
      links.forEach((link, i) => {
        if (i === index) {
          link.dataset.active = "true"
          link.scrollIntoView({ block: "nearest" })
        } else {
          delete link.dataset.active
        }
      })
    }

    private onDialogKeydown = (event: KeyboardEvent) => {
      const links = this.links
      if (event.key === "ArrowDown") {
        event.preventDefault()
        if (links.length) this.setActive((this.activeIndex + 1) % links.length)
      } else if (event.key === "ArrowUp") {
        event.preventDefault()
        if (links.length)
          this.setActive((this.activeIndex - 1 + links.length) % links.length)
      } else if (event.key === "Enter") {
        const link = links[this.activeIndex]
        if (link) {
          event.preventDefault()
          link.click()
        }
      }
    }
  }

  if (!customElements.get("site-search")) {
    customElements.define("site-search", SiteSearch)
  }
</script>
